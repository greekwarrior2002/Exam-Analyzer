# ---- Supabase ----
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role (server-only; never expose to client).
# Used for signed URL creation and privileged DB ops.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ---- AI / OCR ----
# Claude handles both OCR (vision) and grading by default.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Model selection (override if you want cheaper/faster).
ANTHROPIC_MODEL_OCR=claude-sonnet-4-6
ANTHROPIC_MODEL_GRADING=claude-opus-4-7

# ---- Access control (personal use) ----
# Comma-separated list of emails allowed to sign in.
# Only your own email(s). Anyone else is rejected at auth.
ALLOWED_EMAILS=you@example.com

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
